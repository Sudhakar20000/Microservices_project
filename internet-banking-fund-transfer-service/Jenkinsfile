pipeline {
    agent { label 'Node1' }

    environment {
        JAVA_HOME    = "/usr/lib/jvm/java-21-openjdk-amd64"
        PATH         = "${JAVA_HOME}/bin:${env.PATH}"
        DOCKER_USER  = "sudhakar20000"
        SERVICE_DIR  = "internet-banking-fund-transfer-service"
        SERVICE_NAME = "fund-transfer"
        IMAGE_TAG    = "${BUILD_NUMBER}"
    }

    stages {

        stage('Checkout') {
            steps {
                checkout scm
                echo "Building: fund-transfer | Branch: ${env.BRANCH_NAME} | Tag: ${BUILD_NUMBER}"
            }
        }

        stage('Build') {
            steps {
                dir("internet-banking-fund-transfer-service") {
                    sh 'chmod +x gradlew'
                    sh './gradlew clean build -x test --no-daemon'
                }
            }
        }

        stage('SonarQube Analysis') {
            steps {
                withSonarQubeEnv('sonarqube-scanner') {
                    script {
                        def scannerHome = tool 'sonarqube-scanner'
                        dir("internet-banking-fund-transfer-service") {
                            sh """
                            ${scannerHome}/bin/sonar-scanner \
                              -Dsonar.projectKey=ib-fund-transfer \
                              -Dsonar.projectName=ib-fund-transfer \
                              -Dsonar.sources=src/main \
                              -Dsonar.java.binaries=build/classes/java/main \
                              -Dsonar.exclusions=**/build/**
                            """
                        }
                    }
                }
            }
        }

        stage('Quality Gate') {
            steps {
                timeout(time: 5, unit: 'MINUTES') {
                    waitForQualityGate abortPipeline: true
                }
            }
        }

        stage('Docker Build and Push') {
            steps {
                script {
                    def imageName = "sudhakar20000/fund-transfer:${BUILD_NUMBER}"
                    dir("internet-banking-fund-transfer-service") {
                        docker.withRegistry('https://index.docker.io/v1/', 'Dockerhub') {
                            echo "Building Docker image: ${imageName}"
                            def img = docker.build(imageName, ".")
                            img.push()
                            img.push('latest')
                        }
                    }
                }
            }
        }

        stage('Trivy Image Scan') {
            steps {
                script {
                    def imageName = "sudhakar20000/fund-transfer:${BUILD_NUMBER}"
                    def reportFile = "trivy-report-fund-transfer.txt"
                    echo "Running Trivy security scan on: ${imageName}"

                    sh """
                        trivy image \
                            --exit-code 0 \
                            --severity LOW,MEDIUM,HIGH,CRITICAL \
                            --format table \
                            --output ${reportFile} \
                            --no-progress \
                            ${imageName}

                        echo "Trivy scan complete"
                        cat ${reportFile}
                    """

                    def criticalCount = sh(
                        returnStdout: true,
                        script: """trivy image \
                            --exit-code 0 \
                            --severity CRITICAL \
                            --format json \
                            --no-progress \
                            ${imageName} | python3 -c 'import sys,json; data=json.load(sys.stdin); print(sum(len(r.get("Vulnerabilities") or []) for r in data.get("Results", [])))'"""
                    ).trim()

                    echo "Critical vulnerabilities found: ${criticalCount}"
                    if (criticalCount.toInteger() > 10) {
                        echo "WARNING: ${criticalCount} critical vulnerabilities found in ${imageName}"
                    } else {
                        echo "Trivy scan passed - ${criticalCount} critical vulnerabilities"
                    }
                }
            }
            post {
                always {
                    archiveArtifacts artifacts: "trivy-report-fund-transfer.txt",
                                     allowEmptyArchive: true,
                                     fingerprint: true
                }
            }
        }

        stage('Deploy to Kubernetes') {
            steps {
                withCredentials([file(credentialsId: 'kubeconfig', variable: 'KUBECONFIG')]) {
                    sh """
                        kubectl create namespace banking \
                            --kubeconfig=$KUBECONFIG \
                            --dry-run=client -o yaml | \
                            kubectl apply -f - --kubeconfig=$KUBECONFIG

                        kubectl set image deployment/fund-transfer \
                            fund-transfer=sudhakar20000/fund-transfer:${BUILD_NUMBER} \
                            -n banking \
                            --kubeconfig=$KUBECONFIG

                        kubectl rollout status deployment/fund-transfer \
                            -n banking \
                            --timeout=300s \
                            --kubeconfig=$KUBECONFIG
                    """
                }
            }
        }

        stage('Cleanup') {
            steps {
                sh "docker rmi sudhakar20000/fund-transfer:${BUILD_NUMBER} || true"
                sh "docker rmi sudhakar20000/fund-transfer:latest || true"
                cleanWs()
            }
        }
    }

    post {
        success {
            echo "fund-transfer pipeline SUCCESS - image: sudhakar20000/fund-transfer:${BUILD_NUMBER}"
        }
        failure {
            echo "fund-transfer pipeline FAILED"
        }
    }
}

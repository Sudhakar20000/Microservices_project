pipeline {
    agent { label 'Node1' }

    environment {
        JAVA_HOME    = "/usr/lib/jvm/java-21-openjdk-amd64"
        PATH         = "${JAVA_HOME}/bin:${env.PATH}"
        DOCKER_USER  = "sudhakar20000"
        SERVICE_DIR  = "internet-banking-fund-transfer-service"
        SERVICE_NAME = "fund-transfer"
        IMAGE_TAG    = "${BUILD_NUMBER}"
    }

    stages {

        stage('Checkout') {
            steps {
                checkout scm
                echo "Building: fund-transfer | Branch: ${env.BRANCH_NAME} | Tag: ${IMAGE_TAG}"
            }
        }

        stage('Build & Test') {
            steps {
                dir("internet-banking-fund-transfer-service") {
                    sh 'chmod +x gradlew'
                    sh './gradlew clean build --no-daemon'
                }
            }
            post {
                always {
                    junit allowEmptyResults: true,
                          testResults: "internet-banking-fund-transfer-service/build/test-results/**/*.xml"
                }
            }
        }

        stage('SonarQube Analysis') {
            steps {
                withSonarQubeEnv('sonarqube-scanner') {
                    script {
                        def scannerHome = tool 'sonarqube-scanner'
                        dir("internet-banking-fund-transfer-service") {
                            sh "${scannerHome}/bin/sonar-scanner -Dsonar.projectKey=ib-fund-transfer -Dsonar.projectName=ib-fund-transfer -Dsonar.sources=src/main -Dsonar.tests=src/test -Dsonar.java.binaries=build/classes/java/main -Dsonar.exclusions=**/build/**"
                        }
                    }
                }
            }
        }

        stage('Quality Gate') {
            steps {
                timeout(time: 5, unit: 'MINUTES') {
                    waitForQualityGate abortPipeline: true
                }
            }
        }

        stage('Docker Build & Push') {
            steps {
                script {
                    dir("internet-banking-fund-transfer-service") {
                        docker.withRegistry('https://index.docker.io/v1/', 'Dockerhub') {
                            def img = docker.build("sudhakar20000/ib-fund-transfer:${BUILD_NUMBER}", ".")
                            img.push()
                            img.push('latest')
                        }
                    }
                }
            }
        }

        stage('Deploy to Kubernetes') {
            steps {
                withCredentials([file(credentialsId: 'kubeconfig', variable: 'KUBECONFIG')]) {
                    sh """
                        kubectl set image deployment/fund-transfer \
                            fund-transfer=sudhakar20000/ib-fund-transfer:${BUILD_NUMBER} \
                            -n banking --kubeconfig=\$KUBECONFIG

                        kubectl rollout status deployment/fund-transfer \
                            -n banking --timeout=300s --kubeconfig=\$KUBECONFIG
                    """
                }
            }
        }

        stage('Cleanup') {
            steps {
                sh "docker rmi sudhakar20000/ib-fund-transfer:${BUILD_NUMBER} || true"
                sh "docker rmi sudhakar20000/ib-fund-transfer:latest || true"
                cleanWs()
            }
        }
    }

    post {
        success { echo "✅ fund-transfer pipeline SUCCESS" }
        failure { echo "❌ fund-transfer pipeline FAILED" }
    }
}

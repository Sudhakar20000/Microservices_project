pipeline {
    agent { label 'Node1' }

    environment {
        JAVA_HOME    = "/usr/lib/jvm/java-21-openjdk-amd64"
        PATH         = "${JAVA_HOME}/bin:${env.PATH}"
        DOCKER_USER  = "sudhakar20000"
        SERVICE_DIR  = "internet-banking-api-gateway"
        SERVICE_NAME = "api-gateway"
        IMAGE_TAG    = "${BUILD_NUMBER}"
    }

    stages {

        stage('Checkout') {
            steps {
                checkout scm
                echo "Building: api-gateway | Branch: ${env.BRANCH_NAME} | Tag: ${BUILD_NUMBER}"
            }
        }

        stage('Build') {
            steps {
                dir("internet-banking-api-gateway") {
                    sh 'chmod +x gradlew'
                    sh './gradlew clean build -x test --no-daemon'
                }
            }
        }

        stage('SonarQube Analysis') {
            steps {
                withSonarQubeEnv('sonarqube-scanner') {
                    script {
                        def scannerHome = tool 'sonarqube-scanner'
                        dir("internet-banking-api-gateway") {
                            sh """
                            ${scannerHome}/bin/sonar-scanner \
                              -Dsonar.projectKey=ib-api-gateway \
                              -Dsonar.projectName=ib-api-gateway \
                              -Dsonar.sources=src/main \
                              -Dsonar.java.binaries=build/classes/java/main \
                              -Dsonar.exclusions=**/build/**
                            """
                        }
                    }
                }
            }
        }

        stage('Quality Gate') {
            steps {
                timeout(time: 5, unit: 'MINUTES') {
                    waitForQualityGate abortPipeline: true
                }
            }
        }

        stage('Docker Build and Push') {
            steps {
                script {
                    def imageName = "sudhakar20000/api-gateway:${BUILD_NUMBER}"
                    dir("internet-banking-api-gateway") {
                        docker.withRegistry('https://index.docker.io/v1/', 'Dockerhub') {
                            echo "Building Docker image: ${imageName}"
                            def img = docker.build(imageName, ".")
                            img.push()
                            img.push('latest')
                        }
                    }
                }
            }
        }

        stage('Trivy Image Scan') {
            steps {
                script {
                    def imageName = "sudhakar20000/api-gateway:${BUILD_NUMBER}"
                    echo "Running Trivy security scan on: ${imageName}"

                    sh """
                        trivy image \
                            --exit-code 0 \
                            --severity LOW,MEDIUM,HIGH,CRITICAL \
                            --format table \
                            --output trivy-report-api-gateway.txt \
                            --no-progress \
                            ${imageName}

                        echo "Trivy scan complete. Summary:"
                        cat trivy-report-api-gateway.txt
                    """

                    sh """
                        CRITICAL_COUNT=$(trivy image \
                            --exit-code 0 \
                            --severity CRITICAL \
                            --format json \
                            --no-progress \
                            ${imageName} | python3 -c "
import sys, json
data = json.load(sys.stdin)
count = sum(len(r.get('Vulnerabilities') or []) for r in data.get('Results', []))
print(count)
")
                        echo "Critical vulnerabilities found: $CRITICAL_COUNT"
                        if [ "$CRITICAL_COUNT" -gt 10 ]; then
                            echo "WARNING: $CRITICAL_COUNT critical vulnerabilities in ${imageName}"
                        fi
                    """
                }
            }
            post {
                always {
                    archiveArtifacts artifacts: "trivy-report-api-gateway.txt",
                                     allowEmptyArchive: true,
                                     fingerprint: true
                }
            }
        }

        stage('Deploy to Kubernetes') {
            steps {
                withCredentials([file(credentialsId: 'kubeconfig', variable: 'KUBECONFIG')]) {
                    sh """
                        kubectl create namespace banking \
                            --kubeconfig=$KUBECONFIG \
                            --dry-run=client -o yaml | \
                            kubectl apply -f - --kubeconfig=$KUBECONFIG

                        kubectl set image deployment/api-gateway \
                            api-gateway=sudhakar20000/api-gateway:${BUILD_NUMBER} \
                            -n banking \
                            --kubeconfig=$KUBECONFIG

                        kubectl rollout status deployment/api-gateway \
                            -n banking \
                            --timeout=300s \
                            --kubeconfig=$KUBECONFIG
                    """
                }
            }
        }

        stage('Cleanup') {
            steps {
                sh "docker rmi sudhakar20000/api-gateway:${BUILD_NUMBER} || true"
                sh "docker rmi sudhakar20000/api-gateway:latest || true"
                cleanWs()
            }
        }
    }

    post {
        success {
            echo "api-gateway pipeline SUCCESS - image: sudhakar20000/api-gateway:${BUILD_NUMBER}"
        }
        failure {
            echo "api-gateway pipeline FAILED"
        }
    }
}

pipeline {
    agent { label 'Node1' }

    environment {
        JAVA_HOME    = "/usr/lib/jvm/java-21-openjdk-amd64"
        PATH         = "${JAVA_HOME}/bin:${env.PATH}"
        DOCKER_USER  = "sudhakar20000"
        SERVICE_DIR  = "internet-banking-api-gateway"
        SERVICE_NAME = "api-gateway"
        IMAGE_TAG    = "${BUILD_NUMBER}"
    }

    stages {

        stage('Checkout') {
            steps {
                checkout scm
                echo "Building: api-gateway | Branch: ${env.BRANCH_NAME} | Tag: ${IMAGE_TAG}"
            }
        }

        stage('Build') {
            steps {
                dir("internet-banking-api-gateway") {
                    sh 'chmod +x gradlew'
                    sh './gradlew clean build -x test --no-daemon'
                }
            }
        }

        stage('SonarQube Analysis') {
            steps {
                withSonarQubeEnv('sonarqube-scanner') {
                    script {
                        def scannerHome = tool 'sonarqube-scanner'
                        dir("internet-banking-api-gateway") {
                            sh """
                            ${scannerHome}/bin/sonar-scanner \
                              -Dsonar.projectKey=ib-api-gateway \
                              -Dsonar.projectName=ib-api-gateway \
                              -Dsonar.sources=src/main \
                              -Dsonar.java.binaries=build/classes/java/main \
                              -Dsonar.exclusions=**/build/**
                            """
                        }
                    }
                }
            }
        }

        stage('Quality Gate') {
            steps {
                timeout(time: 5, unit: 'MINUTES') {
                    waitForQualityGate abortPipeline: true
                }
            }
        }

        stage('Docker Build & Push') {
            steps {
                script {
                    dir("internet-banking-api-gateway") {
                        docker.withRegistry('https://index.docker.io/v1/', 'Dockerhub') {
                            def img = docker.build("/ib-api-gateway:${BUILD_NUMBER}", ".")
                            img.push()
                            img.push('latest')
                        }
                    }
                }
            }
        }

        stage('Deploy to Kubernetes') {
            steps {
                withCredentials([file(credentialsId: 'kubeconfig', variable: 'KUBECONFIG')]) {
                    sh """
                        # Step 1: Ensure namespace exists
                        kubectl create namespace banking \
                            --kubeconfig=$KUBECONFIG \
                            --dry-run=client -o yaml | \
                            kubectl apply -f - --kubeconfig=$KUBECONFIG

                        # Step 2: Update image tag on existing deployment
                        kubectl set image deployment/api-gateway \
                            api-gateway=/ib-api-gateway:${BUILD_NUMBER} \
                            -n banking \
                            --kubeconfig=$KUBECONFIG

                        # Step 3: Wait for rollout to complete
                        kubectl rollout status deployment/api-gateway \
                            -n banking \
                            --timeout=300s \
                            --kubeconfig=$KUBECONFIG
                    """
                }
            }
        }

        stage('Cleanup') {
            steps {
                sh "docker rmi /ib-api-gateway:${BUILD_NUMBER} || true"
                sh "docker rmi /ib-api-gateway:latest || true"
                cleanWs()
            }
        }
    }

    post {
        success { echo "✅ api-gateway pipeline SUCCESS — image: /ib-api-gateway:${BUILD_NUMBER}" }
        failure { echo "❌ api-gateway pipeline FAILED" }
    }
}
